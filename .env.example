# Copy this file to `.env` and fill in your own values.
# These are EXPO_PUBLIC_* vars, so they are embedded in the client build.
# The app runs on mock data if these are unset (see src/api/main.js).

# HitchLink Identity service (auth)
EXPO_PUBLIC_API_BASE_URL=https://your-identity-host.example.com

# HitchLink Main service (loads, chat, etc.)
EXPO_PUBLIC_API_MAIN_URL=https://your-main-host.example.com
